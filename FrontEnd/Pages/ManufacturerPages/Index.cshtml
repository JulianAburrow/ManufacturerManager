@page
@model ManufacturerManager.FrontEnd.ManufacturerPages.IndexModel

@{
    ViewData["Title"] = "Manufacturers";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<p>
    @Model.Manufacturer.Count record@(Model._replacementHelper.ShowCorrectRecordText(@Model.Manufacturer.Count)) found
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Manufacturer[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Manufacturer[0].ManufacturerStatus)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Manufacturer) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ManufacturerStatus.StatusName)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.ManufacturerId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.ManufacturerId">Details</a>
            </td>
        </tr>
}
    </tbody>
</table>
