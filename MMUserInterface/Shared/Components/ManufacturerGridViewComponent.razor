<MudTable Items="Manufacturers"
          Hover
          FixedHeader="true">
    <HeaderContent>
        <MudTh title="Sort by Manufacturer Name">
            <MudTableSortLabel SortBy="new Func<ManufacturerSummary, object>(x => x.Name)">
                Name
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Status">
            <MudTableSortLabel SortBy="@((ManufacturerSummary x) => x.StatusName ?? "Unknown")">
                Status
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Widget Count">
            <MudTableSortLabel SortBy="new Func<ManufacturerSummary, object>(x => x.WidgetCount)">
                Widget Count
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.StatusName</MudTd>
        <MudTd>@context.WidgetCount</MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Visibility"
                           Href=@($"/manufacturer/view/{context.ManufacturerId}")>
                    View
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Edit"
                           Href=@($"/manufacturer/edit/{context.ManufacturerId}")>
                    Edit
                </MudButton>

            </MudStack>

        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 15, int.MaxValue }" />
    </PagerContent>
</MudTable>