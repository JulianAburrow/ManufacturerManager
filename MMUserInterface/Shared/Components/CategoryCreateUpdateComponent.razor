<MudCardContent>
    <MudTextField id="txtCategory" Label="Name" @bind-Value="CategoryDisplayModel.Name" AutoFocus OnlyValidateIfDirty="true" />
</MudCardContent>
<MudCardActions>

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

        <MudButton Variant="Variant.Filled"
                   ButtonType="ButtonType.Submit"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Check">
            @(CategoryDisplayModel.CategoryId == 0 ? "Create" : "Update")
        </MudButton>

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="/categories/index">
            Cancel
        </MudButton>

    </MudStack>

</MudCardActions>