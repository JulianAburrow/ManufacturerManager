
<DataAnnotationsValidator />
<ValidationSummary />

<MudGrid>
    <MudItem sm="7">
        <MudCard>
            <MudCardContent>
                <MudTextField id="txtName" Label="Name" @bind-Value="ManufacturerDisplayModel.Name" AutoFocus OnlyValidateIfDirty="true" />
                <MudSelect id="ddlStatus" Label="Status" @bind-Value="ManufacturerDisplayModel.StatusId"
                           HelperText="@(ManufacturerDisplayModel.StatusId == 2 && ManufacturerDisplayModel.ManufacturerId > 0 ? "All Widgets for this manufacturer will also have their status set to 'Inactive'" : "")">
                    @foreach (var manufacturerStatus in ManufacturerStatuses)
                    {
                        <MudSelectItem T="int" Value="manufacturerStatus.StatusId">
                            @manufacturerStatus.StatusName
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudCardContent>
            <MudCardActions Class="gap-2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           ButtonType="ButtonType.Submit">
                    @(ManufacturerDisplayModel.ManufacturerId == 0 ? "Create" : "Update")
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Href="/manufacturers/index">
                    Cancel
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>