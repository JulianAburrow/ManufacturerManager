<MudTable Items="Categories"
          SortLabel="SortBy"
          Hover
          RowsPerPage="10"
          FixedHeader
          Height="500px">
    <HeaderContent>
        <MudTh title="Sort by Name">
            <MudTableSortLabel SortBy="new Func<CategoryModel, object>(x => x.Name)">
                Name
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Visibility"
                           Href=@($"/category/view/{context.CategoryId}")>
                    View
                </MudButton>

                @if (OkToDeleteOrEdit(context.Name))
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               Href=@($"/category/edit/{context.CategoryId}")>
                        Edit
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Delete"
                               Href=@($"/category/delete/{context.CategoryId}")>
                        Delete
                    </MudButton>
                }

            </MudStack>

        </MudTd>

    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50, 100, int.MaxValue }" />
    </PagerContent>
</MudTable>