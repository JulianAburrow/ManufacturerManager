<MudTable Items="MyMMs"
          Hover
          FixedHeader="true">
    <HeaderContent>
        <MudTh title="Sort by Title">
            <MudTableSortLabel SortBy="new Func<MyMMModel, object>(x => x.Title)">
                Title
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by URL">
            <MudTableSortLabel SortBy="@((MyMMModel x) => x.URL?.ToString() ?? "None")">
                URL
            </MudTableSortLabel>
        </MudTh>
        <MudTh>
            Notes
        </MudTh>
        <MudTh title="Sort by Action Date">
            <MudTableSortLabel SortBy="@((MyMMModel x) => x.ActionDate.ToString() ?? "None")">
                Action Date
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Is External">
            <MudTableSortLabel SortBy="new Func<MyMMModel, object>(x => x.IsExternal)">
                Is External
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Status">
            <MudTableSortLabel SortBy="new Func<MyMMModel, object>(x => x.Status.StatusName)">
                Status
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Title</MudTd>
        <MudTd>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@(context.IsExternal ? Icons.Material.Filled.OpenInNew : null)"
                       Href="@context.URL"
                       Target="@(context.IsExternal ? "_blank" : "_self")">
                @context.URL
            </MudButton>

        </MudTd>
        <MudTd title="@context.Notes">
            @(context.Notes is not null
                        ? (context.Notes.Length >= 22
                        ? $"{context.Notes.Substring(0, 22)} ..."
                        : context.Notes)
                        : "None")
        </MudTd>
        <MudTd>@(context.ActionDate != null ? context.ActionDate : "None")</MudTd>
        <MudTd>@context.IsExternal</MudTd>
        <MudTd>@context.Status.StatusName</MudTd>
        <MudTd>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Visibility"
                           Href=@($"/mymm/view/{context.MyMMId}")>
                    View
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Edit"
                           Href=@($"/mymm/edit/{context.MyMMId}")>
                    Edit
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Href=@($"/mymm/delete/{context.MyMMId}")>
                    Delete
                </MudButton>

            </MudStack>

        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 15, int.MaxValue }" />
    </PagerContent>
</MudTable>