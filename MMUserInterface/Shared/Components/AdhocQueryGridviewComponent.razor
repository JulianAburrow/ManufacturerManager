<MudTable Items="AdhocQueries"
          SortLabel="SortBy"
          Hover
          RowsPerPage="5"
          FixedHeader>
    <HeaderContent>
        <MudTh title="Sort by Name">
            <MudTableSortLabel SortBy="new Func<AdhocQueryModel, object>(x => x.NaturalLanguageQuery)">
                Natural Language Query
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Is Successful">
            <MudTableSortLabel SortBy="new Func<AdhocQueryModel, object>(x => x.IsSuccessful)">
                Is Successful
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by When Run">
            <MudTableSortLabel SortBy="new Func<AdhocQueryModel, object>(x => x.WhenRun)">
                When Run
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by AI Provider">
            <MudTableSortLabel SortBy="new Func<AdhocQueryModel, object>(x => x.AiProvider)">
                AI Provider
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.NaturalLanguageQuery</MudTd>
        <MudTd>@context.IsSuccessful</MudTd>
        <MudTd>@context.WhenRun</MudTd>
        <MudTd>@context.AiProvider</MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Visibility"
                           Href=@($"/adhocquery/view/{context.AdhocQueryId}")>
                    View
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Href=@($"/adhocquery/delete/{context.AdhocQueryId}")>
                    Delete
                </MudButton>

            </MudStack>

        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50, 100, int.MaxValue }" />
    </PagerContent>
</MudTable>