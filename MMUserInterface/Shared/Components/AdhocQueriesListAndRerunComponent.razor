<MudText Typo="Typo.body1" Class="fw-bold">
    Last @LastXSuccessfulAdhocQueries.Count Successful Queries
</MudText>



<table cellspacing="5">
    @foreach (var query in LastXSuccessfulAdhocQueries)
    {
        <tr>
            <td>@query.NaturalLanguageQuery</td>   
            <td>
                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           Class="my-1 ml-2"
                           OnClick="@(() => OnAdhocQuerySelected.InvokeAsync(query.NaturalLanguageQuery))">
                    Rerun
                </MudButton>
            </td>
        </tr>
    }
</table>