<MudText Typo="Typo.h3" GutterBottom="true">Your Query Results</MudText>

@if (AdhocQueryResults is null || AdhocQueryResults.Rows.Count == 0)
{
    <MudText>No results to display.</MudText>
    return;
}

<MudTable T="DataRow" Items="@(AdhocQueryResults.Rows.Cast<DataRow>())" Hover="true" FixedHeader="true">
    <HeaderContent>
        @foreach (DataColumn col in AdhocQueryResults.Columns)
        {
            <MudTh>@col.ColumnName</MudTh>
        }
    </HeaderContent>

    <RowTemplate>
        @foreach (var item in context.ItemArray)
        {
            <MudTd>@item</MudTd>
        }
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50, 100, int.MaxValue }" />
    </PagerContent>
</MudTable>