@page "/help"
@inherits HelpBasePageClass

<PageTitle>Help</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Help</MudText>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@HelpCategoryPlural" />
    return;
}

@if (IsError)
{
    <MudAlert Severity="Severity.Error" Elevation="0" Variant="Variant.Filled" Class="mb-4">
        @ErrorMessage
    </MudAlert>
    return;
}

<MudText Typo="Typo.body1" GutterBottom="true">Select a category from which you require help and type your question</MudText>

<MudGrid>
    <MudItem sm="7">
        <MudCard>
            <MudCardContent>
                <MudSelect
                    T="string"
                    id="ddlHelpCategories"
                    Label="Category"
                    data-testid="category-select"
                    @bind-Value="ChatSearchModel.SearchCategory">
                    @foreach (var helpCategory in HelpCategories)
                    {
                        <MudSelectItem T="string" Value="@helpCategory">
                            @helpCategory
                        </MudSelectItem>
                    }
                </MudSelect>
                <MudTextField
                    T="string"
                    id="txtHelpSearch"
                    Label="Type your question here"
                    data-testid="question-input"
                    @bind-Value="ChatSearchModel.SearchQuestion" />
                <MudSelect
                    T="string"
                    Label="Respond in"
                    @bind-Value="ChatSearchModel.LanguageRequired">
                    @foreach (var language in Languages)
                    {
                        
                        <MudSelectItem T="string" Value="@language.EnglishName">
                            <MudTooltip Text=@($"{@language.OriginalName} / {@language.TransliteratedName} / {@language.Code}")>
                                @language.EnglishName
                            </MudTooltip>
                        </MudSelectItem>
                    }
                </MudSelect>
                @if (OfflineMode)
                {
                    <MudSelect T="string"
                               id="ddlModels"
                               Label="Model"
                               data-testid="model-select"
                               @bind-Value="ChatSearchModel.SearchModel">
                        @foreach (var availableModel in AvailableModels)
                        {
                            <MudSelectItem T="string" Value="@availableModel.Name">
                                @availableModel.Name (@GetTooltip(availableModel.Size))
                            </MudSelectItem>
                        }
                    </MudSelect>
                }
            </MudCardContent>                       
            <MudCardActions>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="@OnSearchClicked"
                           Disabled="@IsThinking"
                           StartIcon="@Icons.Material.Filled.Check">
                    Submit
                </MudButton>

            </MudCardActions>

        </MudCard>
    </MudItem>
</MudGrid>

<br />
<br />

@if (IsThinking)
{
    <ThinkingComponent />
}

@if (MatchingFiles.Count > 0)
{
    <MudTable Items="MatchingFiles">
        <RowTemplate>
            @{
                var filename = Path.GetFileName(context);
                var link = $"/Documents/{ChatSearchModel.SearchCategory}/{filename}";
            }
            <MudTr Class="spaced-row">
                <MudTd>@filename</MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.OpenInNew"
                               Href="@link"
                               Target="_blank">
                        View
                    </MudButton>
                </MudTd>
            </MudTr>
        </RowTemplate>
    </MudTable>
}

@if (!string.IsNullOrWhiteSpace(Response))
{
    <MudPaper Class="mt-4 pa-3">
        <MudText Typo="Typo.h6">🧠 Response</MudText>
        <MudText data-testid="model-response">@Response</MudText>
    </MudPaper>
}
