@page "/adhocquery/view/{AdhocQueryId:int}"
@inherits AdhocQueryBasePageClass

<PageTitle>View Ad Hoc Query</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@AdhocQuerySingular" />
    return;
}

<MudGrid>
    <MudItem sm="7">
        <MudCard>
            <MudCardContent>
                <MudField Label="Name">@AdhocQueryModel.NaturalLanguageQuery</MudField>
                <MudField Label="Message or Sql Returned">@AdhocQueryModel.MessageOrSqlReturned</MudField>
                <MudField Label="When Run">@AdhocQueryModel.WhenRun</MudField>
                <MudField Label="Is Successful">@AdhocQueryModel.IsSuccessful</MudField>
                <MudField Label="AI Provider">@AdhocQueryModel.AiProvider</MudField>
            </MudCardContent>
            <MudCardActions Class="gap-2">

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Delete"
                               Href=@($"/adhocquery/delete/{AdhocQueryModel.AdhocQueryId}")>
                        Delete
                    </MudButton>

                    @if (AdhocQueryModel.IsSuccessful)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                   OnClick="CopySql">
                            Copy SQL
                        </MudButton>
                    }

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               Href="/adhocqueries/index">
                        Cancel
                    </MudButton>

                </MudStack>

            </MudCardActions>

        </MudCard>
    </MudItem>
</MudGrid>