@page "/llm/delete/{LLmName}"
@inherits LLMBasePageClass

<PageTitle>Delete LLM</PageTitle>

@if (OllamaModel?.Name == string.Empty)
{
    <LoadingMessageComponent ValueToShow="@LLMSingular" />
    return;
}

<ConfirmDeleteComponent ObjectType="@LLMSingular" ObjectName="@OllamaModel?.Name" />

<MudDivider Class="my-4" />

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

    <MudButton Variant="Variant.Filled"
               Color="Color.Error"
               StartIcon="@Icons.Material.Filled.Delete"
               OnClick="DeleteLLM">
        Delete
    </MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/llms/index">
        Cancel
    </MudButton>

</MudStack>
