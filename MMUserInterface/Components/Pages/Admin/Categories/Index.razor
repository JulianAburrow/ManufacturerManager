@page "/categories/index"
@inherits CategoryBasePageClass

<PageTitle>Categories</PageTitle>

@if (Categories is null)
{
    <LoadingMessageComponent ValueToShow="@CategoryPlural" />
    return;
}

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Add"
           Href="/category/create">
    Create Category
</MudButton>

<MudDivider Class="my-4" />

@if (Categories.Count == 0)
{
    <NoResultsComponent ObjectType="@CategoryPlural" />
    return;
}
<CategoryGridViewComponent Categories="Categories" />