@page "/category/view/{CategoryId:int}"
@inherits CategoryBasePageClass

<PageTitle>View Category</PageTitle>

@if (CategoryModel.CategoryId == 0)
{
    <LoadingMessageComponent ValueToShow="@Category" />
    return;
}

<MudGrid>
    <MudItem sm="7">
        <MudCard>
            <MudCardContent>
                <MudField Label="Name">@CategoryModel.Name</MudField>
            </MudCardContent>
            <MudCardActions>

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

                    @if (OkToDeleteOrEdit)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Href=@($"/category/edit/{CategoryModel.CategoryId}")>
                            Edit
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   Href=@($"/category/delete/{CategoryModel.CategoryId}")>
                            Delete
                        </MudButton>
                    }

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               Href="/categories/index">
                        Cancel
                    </MudButton>

                </MudStack>

            </MudCardActions>

        </MudCard>
    </MudItem>
</MudGrid>

