@page "/category/edit/{CategoryId:int}"
@inherits CategoryBasePageClass

<PageTitle>Edit Category</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@(_entityNotFound
                                                ? CategoryNotFoundMessage
                                                : LoadingCategoryMessage)"
                             IsLoading="@(CategoryModel.CategoryId != 0)" />
    return;
}

@if (!OkToDeleteOrEdit)
{
    <CannotDeleteOrEditCategoryComponent />

    <MudDivider Class="my-2" />

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/categories/index">
        Cancel
    </MudButton>
    return;
}

@if (CategoryExists)
{
    <CategeoryExistsComponent CategoryName="@CategoryDisplayModel.Name" />
}

<MudDivider Class="my-4" />

<EditForm Model="@CategoryDisplayModel" OnValidSubmit="UpdateCategory">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <MudGrid>
        <MudItem sm="7">
            <MudCard>
                <CategoryCreateUpdateComponent CategoryDisplayModel="@CategoryDisplayModel" />
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>