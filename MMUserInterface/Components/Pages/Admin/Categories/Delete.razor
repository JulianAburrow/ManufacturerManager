@page "/category/delete/{CategoryId:int}"
@inherits CategoryBasePageClass

<PageTitle>Delete Category</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@(_entityNotFound
                                                ? CategoryNotFoundMessage
                                                : LoadingCategoryMessage)"
                             IsLoading="@(CategoryModel.CategoryId != 0)" />
    return;
}

@if (!OkToDeleteOrEdit)
{
    <CannotDeleteOrEditCategoryComponent />
    return;
}

<ConfirmDeleteComponent ObjectType="@Category" ObjectName="@CategoryModel.Name" />

<MudDivider Class="my-4" />

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

    @if (OkToDeleteOrEdit)
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="DeleteCategory">
            Delete
        </MudButton>
    }

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/categories/index">
        Cancel
    </MudButton>

</MudStack>

