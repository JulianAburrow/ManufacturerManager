@page "/colour/edit/{ColourId:int}"
@inherits ColourBasePageClass

<PageTitle>Edit Colour</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@(_entityNotFound
                                                ? ColourNotFoundMessage
                                                : LoadingColourMessage)"
                             IsLoading="@(ColourModel.ColourId != 0)" />
    return;
}

<EditForm Model="@ColourDisplayModel" OnValidSubmit="UpdateColour">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <MudGrid>
        <MudItem sm="7">
            <MudCard>
                <ColourCreateUpdateComponent ColourDisplayModel="@ColourDisplayModel" />
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>