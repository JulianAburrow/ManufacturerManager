@page "/colour/delete/{ColourId:int}"
@inherits ColourBasePageClass

<PageTitle>Delete Colour</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@ColourSingular" />
    return;
}

@if (!OkToDelete)
{
    <CannotDeleteComponent ObjectType="@ColourSingular" ObjectName="@ColourModel.Name" />
    return;
}

<ConfirmDeleteComponent ObjectType="@ColourSingular" ObjectName="@ColourModel.Name" />

<MudDivider Class="my-4" />

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

    @if (OkToDelete)
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="DeleteColour">
            Delete
        </MudButton>
    }

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/colours/index">
        Cancel
    </MudButton>

</MudStack>