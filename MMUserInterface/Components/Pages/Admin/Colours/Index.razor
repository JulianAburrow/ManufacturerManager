@page "/colours/index"
@inherits ColourBasePageClass

<PageTitle>Colours</PageTitle>

@if (Colours is null)
{
    <LoadingMessageComponent ValueToShow="@ColourPlural" />
    return;
}

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Add"
           Href="/colour/create">
    Create Colour
</MudButton>

<MudDivider Class="my-4" />

@if (Colours.Count == 0)
{
    <NoResultsComponent ObjectType="@ColourPlural" />
    return;
}

<ColourGridViewComponent Colours="Colours" />