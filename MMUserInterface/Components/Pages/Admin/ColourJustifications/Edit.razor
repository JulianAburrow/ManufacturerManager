@page "/colourjustification/edit/{ColourJustificationId:int}"
@inherits ColourJustificationBasePageClass

<PageTitle>Edit Colour Justification</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@(_entityNotFound
                                                ? ColourJustificationNotFoundMessage
                                                : LoadingColourJustificationMessage)"
                             IsLoading="@(ColourJustificationModel.ColourJustificationId != 0)" />
    return;
}

<EditForm Model="@ColourJustificationDisplayModel" OnValidSubmit="UpdateColourJustification">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <MudGrid>
        <MudItem sm="7">
            <MudCard>
                <ColourJustificationCreateUpdateComponent ColourJustificationDisplayModel="@ColourJustificationDisplayModel" />
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>