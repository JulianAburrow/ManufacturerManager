@page "/colourjustifications/index"
@inherits ColourJustificationBasePageClass

<PageTitle>Colour Justifications</PageTitle>

@if (ColourJustifications is null)
{
    <LoadingMessageComponent ValueToShow="@ColourJustificationPlural" />
    return;
}

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Add"
           Href="/colourjustification/create">
    Create Colour Justification
</MudButton>

<MudDivider Class="my-4" />

@if (ColourJustifications.Count == 0)
{
    <NoResultsComponent ObjectType="@ColourJustificationPlural" />
    return;
}

<ColourJustificationGridViewComponent ColourJustifications="ColourJustifications" />
