@page "/colourjustification/delete/{ColourJustificationId:int}"
@inherits ColourJustificationBasePageClass

<PageTitle>Delete Colour Justification</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@(_entityNotFound
                                                ? ColourJustificationNotFoundMessage
                                                : LoadingColourJustificationMessage)"
                             IsLoading="@(ColourJustificationModel.ColourJustificationId != 0)" />
    return;
}


@if (!OkToDelete)
{
    <CannotDeleteComponent ObjectType="@ColourJustification" ObjectName="@ColourJustificationModel.Justification" />
    return;
}

<ConfirmDeleteComponent ObjectType="@ColourJustification" ObjectName="@ColourJustificationModel.Justification" />

<MudDivider Class="my-4" />

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

    @if (OkToDelete)
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="DeleteColourJustification">
            Delete
        </MudButton>
    }

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/colourjustifications/index">
        Cancel
    </MudButton>

</MudStack>
