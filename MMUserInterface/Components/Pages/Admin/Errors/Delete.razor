@page "/error/delete/{ErrorId:int}"
@inherits ErrorBasePageClass

<PageTitle>Delete Error</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@ErrorSingular" />
    return;
}

<ConfirmDeleteComponent ObjectType="@ErrorSingular" ObjectName="@ErrorModel.ErrorMessage" />

<MudDivider Class="my-4" />

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

    <MudButton Variant="Variant.Filled"
               Color="Color.Error"
               StartIcon="@Icons.Material.Filled.Delete"
               OnClick="DeleteError">
        Delete
    </MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/errors/index">
        Cancel
    </MudButton>

</MudStack>
