@page "/helpdocuments/index"
@inherits HelpDocumentBasePageClass

<PageTitle>Help Documents</PageTitle>

@if (HelpDocumentModels is null)
{
	<LoadingMessageComponent ValueToShow="@HelpDocumentPlural" />
}

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Upload"
           Href="/helpdocument/upload">
    Upload Help Document
</MudButton>

<MudDivider Class="my-4" />

@if (HelpDocumentModels?.Count == 0)
{
	<NoResultsComponent ObjectType="@HelpDocumentPlural" />
}
else
{
	<HelpDocumentGridViewComponent HelpDocumentModels="HelpDocumentModels" />
}
