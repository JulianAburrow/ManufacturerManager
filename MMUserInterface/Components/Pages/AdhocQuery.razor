@page "/adhocquery"
@inherits AdhocQueryBasePageClass

<PageTitle>Ad Hoc Query</PageTitle>

@if (LastXSuccessfulAdhocQueries is null)
{
    <LoadingMessageComponent ValueToShow="@AdhocQueryPlural" />
    return;
}

<h1>Ad Hoc Query</h1>

@if (ShowLastXPanel)
{
    <AdhocQueriesListAndRerunComponent LastXSuccessfulAdhocQueries="@LastXSuccessfulAdhocQueries"
                                       OnAdhocQuerySelected="HandleRerunQuery" />    
}

<MudButton Color="Color.Secondary"
           Variant="Variant.Outlined"
           Class="my-3"
           OnClick="@(() => ShowLastXPanel = !ShowLastXPanel)"
           Disabled="@IsThinking">
    @(ShowLastXPanel ? "Hide" : "Show") Last @LastXSuccessfulAdhocQueries.Count @AdhocQueryPlural
</MudButton>

<br />
<br />

<MudGrid>
    <MudItem sm="7">
        <MudCard>
            <MudCardContent>
                <MudTextField Lines="5"
                    T="string"
                    id="txtAdhocQuery"
                    Label="Type your query here"
                    AutoFocus="true"
                    data-testid="adhoc-query-input"
                    @bind-Value="QueryText" />
            </MudCardContent>

            <MudCardActions>
                <button class="btn btn-primary" onclick="@OnQueryClicked" disabled="@IsThinking">Submit</button>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

<br />
<br />

@if (IsThinking)
{
    <ThinkingComponent />
}

@if (MessageToDisplay is not null)
{
    <MudAlert Severity="Severity.Error" Elevation="0" Variant="Variant.Filled" Class="mb-4">
        @MessageToDisplay
    </MudAlert>
}

@if (ResultsDataTable is not null && !IsThinking)
{
    <AdHocQueryResultsComponent AdhocQueryResults="ResultsDataTable" />
}