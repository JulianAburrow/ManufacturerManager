@page "/mymm/edit/{MyMMId:int}"
@inherits MyMMBasePageClass

<PageTitle>Edit MyMM</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@(_entityNotFound
                                                ? MyMMNotFoundMessage
                                                : LoadingMyMMMessage)"
                             IsLoading="@(MyMMModel.MyMMId!= 0)" />
    return;
}

<EditForm Model="@MyMMDisplayModel" OnValidSubmit="UpdateMyMM">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <MudGrid>
        <MudItem sm="7">
            <MudCard>
                <MyMMCreateUpdateComponent MyMMDisplayModel="@MyMMDisplayModel" MyMMStatuses="@MyMMStatuses" />
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
