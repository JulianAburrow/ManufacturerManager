@page "/mymm/delete/{MyMMId:int}"
@inherits MyMMBasePageClass

<PageTitle>Delete MyMM</PageTitle>

@if (!_isLoaded)
{
    <LoadingMessageComponent ValueToShow="@MyMM" />
    return;
}

<ConfirmDeleteComponent ObjectType="@MyMM" ObjectName="@MyMMModel.Title" />

<MudDivider Class="my-4" />

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

    <MudButton Variant="Variant.Filled"
               Color="Color.Error"
               StartIcon="@Icons.Material.Filled.Delete"
               OnClick="DeleteMyMM">
        Delete
    </MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/mymms/index">
        Cancel
    </MudButton>

</MudStack>