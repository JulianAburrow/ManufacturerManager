@page "/mymm/view/{MyMMId:int}"
@inherits MyMMBasePageClass

<PageTitle>View MyMM</PageTitle>

@if (MyMMModel.MyMMId == 0)
{
    <LoadingMessageComponent ValueToShow="@MyMM" />
    return;
}

<MudGrid>
    <MudItem sm="7">
        <MudCard>
            <MudCardContent>
                <MudField Label="Title">@MyMMModel.Title</MudField>
                <MudField Label="URL">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.OpenInNew"
                               Href="@MyMMModel.URL"
                               Target="@(MyMMModel.IsExternal ? "_blank" : "_self")">
                        @MyMMModel.URL
                    </MudButton>
                </MudField>
                <MudField Label="Notes">@MyMMModel.Notes</MudField>
                <MudField Label="Action Date">@MyMMModel.ActionDate</MudField>
                <MudField Label="Is External">@MyMMModel.IsExternal</MudField>
                <MudField Label="Status">@MyMMModel.Status.StatusName</MudField>
            </MudCardContent>
            <MudCardActions>

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               Href=@($"/mymm/edit/{MyMMModel.MyMMId}")>
                        Edit
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Delete"
                               Href=@($"/mymm/delete/{MyMMModel.MyMMId}")>
                        Delete
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               Href="/mymms/index">
                        Cancel
                    </MudButton>

                </MudStack>

            </MudCardActions>

        </MudCard>
    </MudItem>
</MudGrid>