@page "/manufacturers/index"
@inherits ManufacturerBasePageClass

<PageTitle>Manufacturers</PageTitle>


<MudContainer Class="mt-1 px-8" MaxWidth="MaxWidth.False">

    @if (Manufacturers is null)
    {
        <LoadingMessageComponent ValueToShow="@ManufacturerPlural" />
        return;
    }

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/manufacturer/create">
            Create Manufacturer
        </MudButton>

        @if (Manufacturers.Count > 0)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportCSV">
                Download as CSV
            </MudButton>
        }
    </MudStack>

    <MudDivider Class="my-4" />

    @if (Manufacturers.Count == 0)
    {
        <NoResultsComponent ObjectType="@ManufacturerPlural" />
        return;
    }

    <ManufacturerGridViewComponent Manufacturers="@Manufacturers" />

</MudContainer>
