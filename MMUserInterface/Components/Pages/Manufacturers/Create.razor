@page "/manufacturer/create"
@inherits ManufacturerBasePageClass

<PageTitle>Create Manufacturer</PageTitle>

@if (ManufacturerStatuses is null)
{
    <LoadingMessageComponent ValueToShow="@Values" />
    return;
}

<MudContainer Class="mt-1 px-8" MaxWidth="MaxWidth.False">

    <EditForm Model="@ManufacturerDisplayModel" OnValidSubmit="CreateManufacturer">

        <ManufacturerCreateUpdateComponent ManufacturerDisplayModel="ManufacturerDisplayModel" ManufacturerStatuses="ManufacturerStatuses" />

    </EditForm>

</MudContainer>