@page "/manufacturer/view/{ManufacturerId:int}"
@inherits ManufacturerBasePageClass

<PageTitle>View Manufacturer</PageTitle>

<MudContainer Class="mt-1 px-8" MaxWidth="MaxWidth.False">

    @if (!_isLoaded)
    {
        <LoadingMessageComponent ValueToShow="@Manufacturer" />
        return;
    }

    <MudPaper Class="p-4">

        <MudStack Spacing="2">

            <MudText Typo="Typo.h5">Manufacturer Details</MudText>

            <MudText><b>Name:</b> @ManufacturerModel.Name</MudText>
            <MudText><b>Status:</b> @ManufacturerModel.Status.StatusName</MudText>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Edit"
                           Href=@($"/manufacturer/edit/{ManufacturerModel.ManufacturerId}")>
                    Edit
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Href="/manufacturers/index">
                    Back to List
                </MudButton>
            </MudStack>

        </MudStack>

    </MudPaper>

    <MudDivider Class="my-4" />

    @if (!ManufacturerModel.Widgets.Any())
    {
        <MudText Typo="Typo.h6">@ManufacturerModel.Name has no widgets.</MudText>
        return;
    }

    <MudText Typo="Typo.h6" GutterBottom="true">Widgets for @ManufacturerModel.Name</MudText>

    <WidgetGridViewComponent Widgets="@WidgetsForManufacturer" />

</MudContainer>