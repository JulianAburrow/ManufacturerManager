@page "/manufacturer/edit/{ManufacturerId:int}"
@inherits ManufacturerBasePageClass

<PageTitle>Edit Manufacturer</PageTitle>

<MudContainer Class="mt-1 px-8" MaxWidth="MaxWidth.False">

    @if (ManufacturerDisplayModel.ManufacturerId == 0 || ManufacturerStatuses is null)
    {
        <LoadingMessageComponent ValueToShow="@Manufacturer" />
        return;
    }

    <EditForm Model="@ManufacturerDisplayModel" OnValidSubmit="@UpdateManufacturer">

        <ManufacturerCreateUpdateComponent ManufacturerDisplayModel="ManufacturerDisplayModel"
                                           ManufacturerStatuses="ManufacturerStatuses" />

    </EditForm>

</MudContainer>