@inherits LayoutComponentBase

<MudThemeProvider Theme="ActiveTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<PageTitle>Manufacturer Manager</PageTitle>

<CascadingValue Value="this">
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
            <MudText Class="header-bar-text">Manufacturer Manager</MudText>
            <MudSpacer />
            <MudText Class="header-bar-text">@HeaderText</MudText>
            <MudTooltip Text="Save to MyMM">
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               Color="Color.Inherit"
                               OnClick="SaveToMyMM" />
            </MudTooltip>
            <MudPaper Style="width: 400px">
                <MudSelect T="string" Value="CurrentTheme" ValueChanged="OnThemeChanged">
                    <MudSelectItem T="string" Value="@ThemeEnum.Standard.ToString()">Standard</MudSelectItem>
                    <MudSelectItem T="string" Value="@ThemeEnum.Large.ToString()">Large</MudSelectItem>
                    <MudSelectItem T="string" Value="@ThemeEnum.ExtraLarge.ToString()">Extra Large</MudSelectItem>
                </MudSelect>
            </MudPaper>
        </MudAppBar>
        <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
            <NavMenu />
        </MudDrawer>
        <MudMainContent>
            <MudBreadcrumbs Items="BreadCrumbs">
                <SeparatorTemplate>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                </SeparatorTemplate>
            </MudBreadcrumbs>
            @Body
        </MudMainContent>
    </MudLayout>
</CascadingValue>